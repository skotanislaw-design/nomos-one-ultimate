# ══════════════════════════════════════════════════════
# Nomos One — Environment Configuration
# Αντιγράψτε: cp .env.example .env  και συμπληρώστε
# ══════════════════════════════════════════════════════

# ── Security ──────────────────────────────────────────
JWT_SECRET=CHANGE_THIS_to_openssl_rand_hex_32_output
JWT_EXPIRY_HOURS=8

# ── MongoDB ───────────────────────────────────────────
MONGO_USER=nomos_admin
MONGO_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_NAME=nomos_one

# ── Admin Account ─────────────────────────────────────
ADMIN_EMAIL=christos@skotanislaw.com
ADMIN_NAME=Χρήστος Σκοτάνης
ADMIN_INITIAL_PASSWORD=CHANGE_ON_FIRST_LOGIN

# ── App ───────────────────────────────────────────────
DOCUMENT_STORAGE_PATH=/data/documents
MAX_FILE_SIZE_MB=50
STAGNANT_DAYS=30
MIN_PASSWORD_LENGTH=8
MAX_LOGIN_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── CORS / URLs ───────────────────────────────────────
# Production: https://nomos.skotanislaw.com
CORS_ORIGINS=https://nomos.skotanislaw.com
VITE_API_URL=https://nomos.skotanislaw.com

# ── SMTP Email (προαιρετικό) ──────────────────────────
# Χωρίς SMTP, τα emails καταγράφονται στη βάση (fallback)
# Gmail App Password: myaccount.google.com → Security → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=christos@skotanislaw.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=christos@skotanislaw.com
SMTP_FROM_NAME=Σκοτάνης & Συνεργάτες
